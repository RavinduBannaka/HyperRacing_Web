# Appwrite client configuration
VITE_APPWRITE_PROJECT_ID=69ef48ea0000670c042a
VITE_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1

# Appwrite database configuration
# Create these collections in Appwrite, then paste their IDs here.
VITE_APPWRITE_DATABASE_ID=
VITE_APPWRITE_CARS_COLLECTION_ID=
VITE_APPWRITE_CATEGORIES_COLLECTION_ID=
VITE_APPWRITE_STORE_CARDS_COLLECTION_ID=
VITE_APPWRITE_USERS_COLLECTION_ID=

# Server-only secret. Never expose this in frontend code.
# Put API keys only in your backend environment, not in Vite variables.
APPWRITE_API_KEY=

# Example values:
# VITE_APPWRITE_PROJECT_ID=abc123
# VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
